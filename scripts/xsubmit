#!/usr/bin/env python3
"""
xsubmit - Submit a job to clusters

Usage:
    xsubmit [options] NAME EXECUTABLE

Arguments:
    NAME: Job name
    EXECUTABLE: Command to run

Options:
    -h, --help               Show help message and exit
    -p, --preset PRESET      Requirement preset to use (e.g. "gpu_interactive", "1gpu_48g_12h")
    -c, --cluster CLUSTER    Target cluster names, use comma to specify multiple clusters, e.g. cluster1,cluster2 (default: all the active clusters)
    -d, --dependency         Job names to wait for, use comma to specify multiple jobs, e.g. prepare_data1,prepare_data2 (default: none)
    -r, --routing            Routing mode to select which cluster to submit to, e.g. round-robin, idle, load, throughput (default: load)
    --dry-run                Show what would be submitted without actually submitting
    --retry NUM_RETRY        Retry the job when it fails (doesn't update dependency chain)
    --interactive            Submit as interactive job (will block and show the command to connect to the job)
"""

import sys
import argparse

from xcer.commands import xsubmit_main
from xcer.utils import expand_combined_flags, maybe_comma_separated_list_str


def main():
    """Main entry point for xsubmit command."""
    parser = argparse.ArgumentParser(
        description="Submit jobs to clusters",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=__doc__,
    )
    parser.add_argument(
        "name",
        help="Job name",
    )
    parser.add_argument(
        "executable",
        help="Command to run",
        nargs="+",
    )
    parser.add_argument(
        "-p",
        "--preset",
        help='Requirement preset to use (e.g. "gpu_interactive", "1gpu_48g_12h")',
        required=True,
    )
    parser.add_argument(
        "-c",
        "--cluster",
        help="Target cluster names, use comma to specify multiple clusters, e.g. cluster1,cluster2 (default: all the active clusters)",
        default=None,
        type=maybe_comma_separated_list_str,
    )
    parser.add_argument(
        "-d",
        "--dependency",
        help="Job names to wait for, use comma to specify multiple jobs, e.g. prepare_data1,prepare_data2 (default: none)",
        default=None,
        type=maybe_comma_separated_list_str,
    )
    parser.add_argument(
        "-r",
        "--routing",
        help="Routing mode to select which cluster to submit to, e.g. round-robin, idle, load, throughput (default: load)",
        default="load",
        choices=["round-robin", "idle", "load", "throughput"],
    )
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Show what would be submitted without actually submitting",
    )
    parser.add_argument(
        "--retry",
        type=int,
        default=0,
        help="Retry the job when it fails (doesn't update dependency chain)",
    )
    parser.add_argument(
        "--interactive",
        action="store_true",
        help="Submit as interactive job",
    )

    args = parser.parse_args(expand_combined_flags(sys.argv[1:]))
    xsubmit_main(args)


if __name__ == "__main__":
    main()
