#!/usr/bin/env python3
"""
xcancel - Cancel jobs across clusters

Usage:
    xcancel [options] ID_OR_NAME

Examples:
    xcancel -c cluster1 host:123456 (cancel job host:123456 on cluster1)
    xcancel -c cluster1 train* (cancel all the jobs which name starts with "train" on cluster1)
    xcancel train* (cancel all the jobs which name starts with "train")
    xcancel -n host:123456 (cancel job with name "host:123456")
    xcancel -r 1h (cancel all the jobs submitted within the last hour)

Arguments:
    ID_OR_NAME: Job ID or name pattern to cancel (e.g. host:123456, host:123456,host:123457, host:123456..123460, train*)
    (If not explicitly specified, pure numerical argument string is treated as ID, otherwise as NAME)

Options:
    -h, --help                   Show help message and exit
    -n, --name                   ID_OR_NAME should be treated as job name
    -i, --id                     ID_OR_NAME should be treated as job ID
    -c, --cluster CLUSTER        Cluster name to cancel jobs on (default: all the active clusters)
    -t, --state STATE            Cancel jobs in specific state (running, pending, etc.)
    -p, --preset PRESET          Cancel jobs with a preset (e.g. "gpu_interactive", "1gpu_48g_12h")
    -a, --aggregate MAX_COUNT    Aggregate jobs by job name prefix so that the displayed name is less than MAX_COUNT
    -r, --rollback TIME          Cancel all jobs submitted within the last TIME (e.g. 1m, 3h)
    -d, --delete                 Delete the specified jobs from the database
    --all                        Cancel all the ongoing jobs
    --dry-run                    Show what would be submitted without actually submitting
"""

import sys
import argparse

from xcer.commands import xcancel_main
from xcer.utils import expand_combined_flags, maybe_comma_separated_list_str


def main():
    """Main entry point for xcancel command."""
    parser = argparse.ArgumentParser(
        description="Cancel jobs across clusters",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=__doc__,
    )

    parser.add_argument(
        "id_or_name",
        help="Job ID or name to cancel",
        nargs="?",
        type=maybe_comma_separated_list_str,
    )
    parser.add_argument(
        "-c",
        "--cluster",
        help="Cluster name to cancel jobs on (default: all the active clusters)",
        default=None,
        type=maybe_comma_separated_list_str,
    )
    parser.add_argument(
        "-n",
        "--name",
        action="store_true",
        help="Using job name to specify jobs",
    )
    parser.add_argument(
        "-i",
        "--id",
        action="store_true",
        help="Using job ID to specify jobs",
    )
    parser.add_argument(
        "-t",
        "--state",
        help="Cancel jobs in specific state (running, pending, etc.)",
        default=None,
    )
    parser.add_argument(
        "-p",
        "--preset",
        help='Cancel jobs with a preset (e.g. "gpu_interactive", "1gpu_48g_12h")',
        default=None,
    )
    parser.add_argument(
        "-a",
        "--aggregate",
        help="Aggregate jobs by job name prefix if the number of clusters is less than MAX_COUNT",
        default=None,
        type=int,
    )
    parser.add_argument(
        "-r",
        "--rollback",
        help="Cancel all jobs submitted within the last TIME (e.g. 1m, 3h)",
        default=None,
    )
    parser.add_argument(
        "-d",
        "--delete",
        action="store_true",
        help="Delete the specified jobs from the database",
    )
    parser.add_argument(
        "--all",
        action="store_true",
        help="Cancel all the ongoing jobs",
    )
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Show what would be submitted without actually submitting",
    )

    args = parser.parse_args(expand_combined_flags(sys.argv[1:]))
    xcancel_main(args)
    # TODO:
    # 0. construct scancel commands
    # 1. send to the remote clusters as needed


if __name__ == "__main__":
    main()
