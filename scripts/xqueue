#!/usr/bin/env python3
"""
xqueue - Check submitted jobs across clusters

Examples:
    xqueue -c cluster1 (show jobs on cluster1)
    xqueue -c cluster1 host:123456..123460 (show jobs with ID in the range of host:123456 to host:123460 on cluster1)
    xqueue -c cluster1 train* (show all the jobs which name starts with "train" on cluster1)
    xqueue train* (show all the jobs which name starts with "train")
    xqueue -c cluster1 -r 1d (show all the jobs submitted within the last 1 day on cluster1)

Arguments:
    ID_OR_NAME: Job ID or name pattern to cancel (e.g. host:123456, host:123456,host:123457, host:123456..123460, train*)
    (If not explicitly specified, pure numerical argument string is treated as ID, otherwise as NAME)

Options:
    -h, --help                   Show help message and exit
    -n, --name                   ID_OR_NAME should be treated as job name
    -i, --id                     ID_OR_NAME should be treated as job ID (host:id format)
    -c, --cluster CLUSTER        Cluster name to show jobs on (default: all the active clusters)
    -t, --state STATE            Show jobs in specific state (running, pending, etc.)
    -p, --preset PRESET          Show jobs with a preset (e.g. "gpu_interactive", "1gpu_48g_12h")
    -a, --aggregate MAX_COUNT    Aggregate jobs by job name prefix, hierarchically clustered to MAX_COUNT
    -r, --recent TIME            Show jobs that submitted in the last TIME, including finished and failed jobs (e.g. "1h", "30m", "2d")
    --all                        Show all the ongoing jobs
"""

import sys
import argparse

from xcer.commands import xqueue_main
from xcer.utils import expand_combined_flags


def main():
    """Main entry point for xqueue command."""
    parser = argparse.ArgumentParser(
        description="Check submitted jobs across clusters",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=__doc__,
    )

    parser.add_argument(
        "id_or_name",
        help="Job ID (host:id format) or name to show",
        default=None,
        nargs="?",
    )
    parser.add_argument(
        "-c",
        "--cluster",
        help="Cluster name to show jobs on (default: all the active clusters)",
        default=None,
    )
    parser.add_argument(
        "-n",
        "--name",
        action="store_true",
        help="ID_OR_NAME should be treated as job name",
    )
    parser.add_argument(
        "-i",
        "--id",
        action="store_true",
        help="ID_OR_NAME should be treated as job ID (host:id format)",
    )
    parser.add_argument(
        "-t",
        "--state",
        help="Show jobs in specific state (running, pending, etc.)",
        default=None,
    )
    parser.add_argument(
        "-p",
        "--preset",
        help='Show jobs with a preset (e.g. "gpu_interactive", "1gpu_48g_12h")',
        default=None,
    )
    parser.add_argument(
        "-a",
        "--aggregate",
        help="Aggregate jobs by job name prefix, hierarchically clustered to MAX_COUNT",
        default=None,
    )
    parser.add_argument(
        "-r",
        "--recent",
        help="Show jobs that submitted in the last TIME, including finished and failed jobs (e.g. '1h', '30m', '2d')",
        default=None,
    )
    parser.add_argument(
        "--all",
        action="store_true",
        help="Show all the ongoing jobs",
    )

    args = parser.parse_args(expand_combined_flags(sys.argv[1:]))
    xqueue_main(args)
    # TODO:
    # 0. let local monitor refresh squeue list
    # 1. collect squeue list from monitor
    # 2. filter squeue list as needed
    # 3. print out the squeue list


if __name__ == "__main__":
    main()
